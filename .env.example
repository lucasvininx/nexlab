# Exemplo de arquivo .env - Configure seus valores reais localmente

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Vercel Blob (File Storage)
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# Database Configuration (Optional)
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.your-supabase-instance.supabase.co
POSTGRES_PASSWORD=your_password_here
POSTGRES_PRISMA_URL=postgres://user:password@host/db
POSTGRES_URL=postgres://user:password@host/db
POSTGRES_URL_NON_POOLING=postgres://user:password@host/db
POSTGRES_USER=postgres

# Supabase Service Keys (Server-side only, keep secret!)
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_URL=https://your-supabase-instance.supabase.co

# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in all values with your actual Supabase credentials
# 3. Never commit .env or .env.local to Git
